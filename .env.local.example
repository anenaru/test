# ─── Sanity ───────────────────────────────────────────────────────────────────
# Get these from https://sanity.io/manage → your project → Settings → API
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Optional: create a read token in Sanity → Settings → API → Tokens
# Only needed if your dataset is set to "private"
# SANITY_API_READ_TOKEN=your_read_token_here

# ─── Contact Form ─────────────────────────────────────────────────────────────
# Get your key from https://resend.com
RESEND_API_KEY=your_resend_api_key_here
